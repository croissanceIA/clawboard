# Requis : chemin vers le dossier cron d'OpenClaw
OPENCLAW_CRON_PATH=/chemin/vers/.openclaw/cron

# Optionnel : chemin absolu vers le binaire openclaw (auto-détecté sinon)
# Sur Mac/Linux natif : le chemin vers le binaire
# OPENCLAW_CLI_PATH=/usr/local/bin/openclaw
# Sur VPS Docker : chemin vers le dossier contenant docker-compose.yml (auto-détecté sinon)
# OPENCLAW_DOCKER_COMPOSE=/opt/app

# Optionnel : valeurs par défaut pour les nouveaux templates
# OPENCLAW_DEFAULT_AGENT=main
# OPENCLAW_DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4
# OPENCLAW_DEFAULT_DELIVERY_CHANNEL=discord

# Optionnel : port (défaut 3000)
# PORT=3000
